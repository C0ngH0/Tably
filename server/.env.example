# Server port (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# AWS Textract credentials (do not commit real values)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenAI repair fallback (do not commit real values)
# Must be an OpenAI API key, not a ChatGPT session token.
OPENAI_API_KEY=sk-your-openai-api-key
# Server port (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# AWS Textract credentials (do not commit real values)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenAI repair fallback (used only when parsed receipt validation mismatches)
OPENAI_API_KEY=
