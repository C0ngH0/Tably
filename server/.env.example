# Server port (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/splitsnap?schema=public

# JWT signing secret (use a long random value in real environments)
JWT_SECRET=replace-with-a-long-random-secret

# Browser origins allowed to call the API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Email delivery
EMAIL_PROVIDER=resend
EMAIL_FROM=
RESEND_API_KEY=
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# AWS Textract configuration
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenAI repair fallback (do not commit real values)
# Must be an OpenAI API key, not a ChatGPT session token.
OPENAI_API_KEY=
